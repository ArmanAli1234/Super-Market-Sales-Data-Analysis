# skew checking
from sklearn.preprocessing import PowerTransformer
pt=PowerTransformer(method='yeo-johnson')
def skew(col):
    result=df[col].skew()
    if result == 0:
        print(f"data is normally distributed: {df[col].skew()}")
    elif result>0:
        print(f"data is right skewed: {df[col].skew()}")
    else:
        print(f"data is left skewed: {df[col].skew()}")
      


skew("Sales")


skew("Profit")


skew("Quantity")


# outlier detection using iqr method
def outlier_detection(col):
    q1=df[col].quantile(0.25)
    q3=df[col].quantile(0.75)
    iqr=q3-q1

    lower_bound=q1-1.5*iqr
    upper_bound=q3+1.5*iqr
    print(lower_bound,upper_bound)

    outliers=df[(df[col]<lower_bound) | (df[col]>upper_bound)]
    return outliers


outlier_detection("Sales").head(4)


outlier_detection("Profit").head()


outlier_detection("Quantity").head()














